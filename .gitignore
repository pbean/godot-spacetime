# Local agent/tool state
.codex/
.agents/
.claude/
_bmad/
_bmad-output/
addons/test_bridge/

# Environment files
.env
.env.*
!.env.example
!.env.sample

# OS and editor noise
.DS_Store
Thumbs.db
Desktop.ini
*.swp
*.swo
*~
.idea/
.vscode/
.vs/

# Godot caches and local editor state
.godot/
.import/
.mono/
mono_crash.*.json
export_credentials.cfg

# Shared export presets can be committed if the demo or packaging flow needs them.

# .NET build outputs and local IDE state
bin/
obj/
TestResults/
packages/
*.user
*.rsuser
*.DotSettings.user
*.suo
*.userprefs
*.sln.docstates
*.nupkg
*.snupkg
*.coverage
coverage/
coverage*.xml

# Release candidate archives (produced by scripts/packaging/package-release.py)
release-candidates/

# Python caches from validation scripts and pytest
__pycache__/
*.py[cod]
.pytest_cache/

# Packaging and release outputs
artifacts/
dist/
release/

# Cargo build outputs from running `spacetime publish` against local modules.
# The codegen script clears these on exit, but the publish path doesn't — so
# developers and CI that run the dynamic lifecycle test (Story 7.1) would
# otherwise see the tree perpetually dirty.
spacetime/modules/*/target/
spacetime/modules/*/Cargo.lock

# Ephemeral per-run output dirs from the D3 live-lane harness
# (EditorCodegenServiceHarness.cs). Each run uses a guid8-suffixed dir and deletes
# it in its finally; this ignore only catches residue from a hard-killed run so it
# is never committed. The rest of tests/fixtures/generated/ (e.g. multi_module_smoke/)
# is tracked and intentionally NOT ignored.
tests/fixtures/generated/d3-harness*/

# General logs and patch leftovers
*.log
*.tmp
*.temp
*.orig
*.rej
.claude/.story-automator-active
